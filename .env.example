# =============================================================
# FlowCA EAI - Shared Environment Configuration
# =============================================================
# Copy this file to .env and adjust values as needed.
# All services read their config from environment variables.
# =============================================================

# --- API Gateway ---
GATEWAY_PORT=3000

# --- POS Service ---
POS_PORT=3001
POS_DB_HOST=pos-mysql
POS_DB_PORT=3306
POS_DB_NAME=pos_db
POS_DB_USER=root
POS_DB_PASSWORD=secret

# --- Inventory Service ---
INVENTORY_PORT=3002
INVENTORY_DB_HOST=inventory-mysql
INVENTORY_DB_PORT=3306
INVENTORY_DB_NAME=inventory_db
INVENTORY_DB_USER=root
INVENTORY_DB_PASSWORD=secret

# --- CRM Service ---
CRM_PORT=3003
CRM_DB_HOST=crm-mysql
CRM_DB_PORT=3306
CRM_DB_NAME=crm_db
CRM_DB_USER=root
CRM_DB_PASSWORD=secret

# --- Accounting Service (C#) ---
ACCOUNTING_PORT=5001
ACCOUNTING_DB_CONNECTION=Data Source=/app/data/accounting.db

# --- RabbitMQ (shared message broker) ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_EXCHANGE=flowca.events
RABBITMQ_ROUTING_KEY=transaction.completed

# --- RabbitMQ Queue Names ---
POS_QUEUE=pos_queue
INVENTORY_QUEUE=inventory_queue
ACCOUNTING_QUEUE=accounting.transactions
ACCOUNTING_DLQ=accounting.transactions.dlq

# --- Gateway Route Targets ---
POS_BASE_URL=http://pos-backend:3001
INVENTORY_BASE_URL=http://inventory-backend:3002
CRM_BASE_URL=http://crm-backend:3003
ACCOUNTING_BASE_URL=http://accounting-service:5000

# --- Frontend Ports (Docker) ---
ACCOUNTING_FRONTEND_PORT=9083
POS_FRONTEND_PORT=9080
INVENTORY_FRONTEND_PORT=9081
CRM_FRONTEND_PORT=9082
